# ===== 飞书自建应用配置 =====
# 飞书应用的 App ID
FEISHU_APP_ID=YOUR_FEISHU_APP_ID
# 飞书应用的 App Secret
FEISHU_APP_SECRET=YOUR_FEISHU_APP_SECRET
# 飞书知识空间 ID
FEISHU_WIKI_SPACE_ID=YOUR_FEISHU_WIKI_SPACE_ID

# ===== Dify 知识库配置 =====
# Dify 知识库 API 访问凭证 (dataset- 开头)
DIFY_API_KEY=YOUR_DIFY_API_KEY
# Dify 刚创建的空知识库 ID
DIFY_DATASET_ID=YOUR_DIFY_DATASET_ID
# Dify API 服务端点 (例：http://your-dify-host/v1)
DIFY_BASE_URL=http://your-dify-host/v1

# ===== 自动执行配置 =====
# 自动定时同步时间间隔（单位：分钟，如：60）
SYNC_INTERVAL_MINUTES=60

# 是否仅执行一次后退出（true / false）
# 如果为 true，则容器在执行完一次同步后立即退出，非常适合作为外部 Crontab 或 K8s CronJob 运行。
RUN_ONCE=false

# ===== 图片同步配置 =====
# 图片服务的公开访问地址 (例：http://192.168.200.240:8089)
# 留空则跳过图片下载，仅以文字占位符导入。
IMAGE_BASE_URL=http://your-host:8089

# 图片服务绑定的宿主机端口 (默认 8089)
IMAGE_PORT=8089

# ===== 知识库分块设置 =====
# 是否启用整篇文档作为一个分段模式 (true / false)
FORCE_SINGLE_CHUNK=true
# 分块最大字数 (max_tokens)，默认 800
MAX_TOKENS=800
# 重叠字符字数 (chunk_overlap)，默认 150
CHUNK_OVERLAP=150
